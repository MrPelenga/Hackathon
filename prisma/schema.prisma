generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum RoomType {
  CLASSROOM
  DORM
  OFFICE
  CAFETERIA
  LAB
  COMMON
  OTHER
}

enum EquipmentType {
  BLIND
  LIGHT
  DOOR
  PRESENCE_SENSOR
  AIR_QUALITY_SENSOR
  COMPUTER
  OTHER
}

enum EquipmentStatus {
  ON
  OFF
  FAULT
  MAINTENANCE
}

enum LightStatus {
  ON
  OFF
  FAULT
}

enum LightMode {
  AUTO
  MANUAL
}

enum HvacMode {
  AUTO
  MANUAL
  ECO
  OFF
}

enum HvacStatus {
  HEATING
  COOLING
  IDLE
  OFF
  FAULT
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IncidentCategory {
  LIGHTING
  HVAC
  BLIND
  EQUIPMENT
  ACCESS
  PARKING
  OTHER
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SensorType {
  TEMPERATURE
  PRESENCE
  ENERGY
  AIR_QUALITY
  HUMIDITY
  LUMINOSITY
}

// ─── CAMPUS INFRASTRUCTURE ───────────────────────────────────────────────────

model Building {
  id         String  @id @default(cuid())
  name       String
  shortName  String  @map("short_name")
  address    String
  floorCount Int     @default(1) @map("floor_count")
  isOpen     Boolean @default(true) @map("is_open")

  zones          Zone[]
  rooms          Room[]
  streetLights   StreetLight[]
  sensorReadings SensorReading[]

  @@map("buildings")
}

model Zone {
  id         String @id @default(cuid())
  buildingId String @map("building_id")
  name       String
  floor      Int    @default(0)

  building  Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms     Room[]
  hvacUnits HvacUnit[]

  @@map("zones")
}

model Room {
  id         String   @id @default(cuid())
  buildingId String   @map("building_id")
  zoneId     String?  @map("zone_id")
  name       String
  type       RoomType
  capacity   Int
  floor      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")

  building       Building        @relation(fields: [buildingId], references: [id])
  zone           Zone?           @relation(fields: [zoneId], references: [id])
  equipment      Equipment[]
  hvacUnits      HvacUnit[]
  sensorReadings SensorReading[]
  incidents      Incident[]

  @@map("rooms")
}

// ─── EQUIPMENT ───────────────────────────────────────────────────────────────

model Equipment {
  id          String          @id @default(cuid())
  roomId      String          @map("room_id")
  name        String
  type        EquipmentType
  status      EquipmentStatus @default(OFF)
  isOnline    Boolean         @default(true) @map("is_online")
  powerWatts  Float           @default(0) @map("power_watts")
  lastUpdated DateTime        @default(now()) @map("last_updated")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("equipment")
}

// ─── HVAC / CLIMATE ──────────────────────────────────────────────────────────

model HvacUnit {
  id                 String     @id @default(cuid())
  zoneId             String?    @map("zone_id")
  roomId             String?    @map("room_id")
  name               String
  mode               HvacMode   @default(AUTO)
  status             HvacStatus @default(IDLE)
  setTemperature     Float      @default(21.0) @map("set_temperature")
  currentTemperature Float      @default(20.0) @map("current_temperature")
  isOnline           Boolean    @default(true) @map("is_online")
  powerWatts         Float?     @map("power_watts")
  lastUpdated        DateTime   @default(now()) @map("last_updated")

  zone           Zone?           @relation(fields: [zoneId], references: [id])
  room           Room?           @relation(fields: [roomId], references: [id])
  sensorReadings SensorReading[]

  @@map("hvac_units")
}

// ─── STREET LIGHTING ─────────────────────────────────────────────────────────

model StreetLight {
  id          String      @id @default(cuid())
  buildingId  String?     @map("building_id")
  identifier  String      @unique
  status      LightStatus @default(ON)
  mode        LightMode   @default(AUTO)
  powerWatts  Float       @default(100) @map("power_watts")
  isOnline    Boolean     @default(true) @map("is_online")
  lastUpdated DateTime    @default(now()) @map("last_updated")

  building Building? @relation(fields: [buildingId], references: [id])

  @@map("street_lights")
}

// ─── SENSOR DATA ─────────────────────────────────────────────────────────────

model SensorReading {
  id         String     @id @default(cuid())
  roomId     String?    @map("room_id")
  hvacUnitId String?    @map("hvac_unit_id")
  buildingId String?    @map("building_id")
  type       SensorType
  value      Float
  unit       String
  timestamp  DateTime   @default(now())

  room     Room?     @relation(fields: [roomId], references: [id])
  hvacUnit HvacUnit? @relation(fields: [hvacUnitId], references: [id])
  building Building? @relation(fields: [buildingId], references: [id])

  @@map("sensor_readings")
}

// ─── INCIDENTS ────────────────────────────────────────────────────────────────

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String
  category    IncidentCategory
  status      IncidentStatus   @default(OPEN)
  priority    IncidentPriority @default(MEDIUM)
  roomId      String?          @map("room_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  resolvedAt  DateTime?        @map("resolved_at")

  room Room? @relation(fields: [roomId], references: [id])

  @@map("incidents")
}

// ─── RFID ACCESS CONTROL & BLOCKCHAIN ────────────────────────────────────────

model RfidReader {
  id            String   @id @default(cuid())
  name          String
  location      String
  building      String
  zone          String
  floor         Int      @default(0)
  securityLevel String   @default("STANDARD") @map("security_level")
  isOnline      Boolean  @default(true) @map("is_online")
  lastSeen      DateTime @default(now()) @map("last_seen")
  allowedRoles  String   @map("allowed_roles")

  events AccessEvent[]

  @@map("rfid_readers")
}

// Blockchain-backed access log — immutable append-only
model AccessEvent {
  id          String   @id @default(cuid())
  blockIndex  Int      @unique @map("block_index")
  badgeNumber String   @map("badge_number")
  holderName  String   @map("holder_name")
  holderRole  String   @map("holder_role")
  readerId    String   @map("reader_id")
  readerName  String   @map("reader_name")
  location    String
  result      String
  reason      String?
  timestamp   DateTime @default(now())
  blockHash   String   @map("block_hash")
  prevHash    String   @map("prev_hash")
  blockData   String   @map("block_data")

  reader RfidReader @relation(fields: [readerId], references: [id])

  @@map("access_events")
}

// Checkpoint of the access-log chain head, anchored automatically on XRPL.
model AccessAnchor {
  id          String   @id @default(cuid())
  chainHead   String   @map("chain_head")
  blockCount  Int      @map("block_count")
  xrplTxHash  String?  @map("xrpl_tx_hash")
  xrplAddress String?  @map("xrpl_address")
  anchoredAt  DateTime @default(now()) @map("anchored_at")

  @@map("access_anchors")
}
